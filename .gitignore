# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =========================

# Node.js / MERN .gitignore

# =========================

# dependencies

node_modules/
frontend/node_modules/
backend/node_modules/

# production build

build/
dist/
frontend/build/
backend/dist/

# environment variables

.env
.env.*
!.env.example

# logs

logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# runtime data

pids
*.pid
*.seed
*.pid.lock

# coverage reports

coverage/
.nyc_output/

# temporary files

tmp/
temp/
*.tmp
*.temp

# OS generated files

.DS_Store
Thumbs.db

# IDE / Editor folders

.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Mac system files

.AppleDouble
.LSOverride

# dotenv backups

.env.local
.env.development.local
.env.test.local
.env.production.local

# lock files (optional – many teams keep them)

# Uncomment if you don't want to commit them

# package-lock.json

# yarn.lock

# pnpm-lock.yaml

# uploads / generated content

uploads/
public/uploads/

# cache

.cache/
.parcel-cache/

# testing

jest-cache/
jest-results.json

# Next.js / frameworks (if used later)

.next/
out/

# misc

*.tgz
*.bak
*.swp
*~

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/

# temporary files
*.tmp
*.temp

# coverage
coverage/

# lock files (optional)
package-lock.json

# backend uploads
uploads/
